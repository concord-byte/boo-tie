generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  company   String?
  phone     String?
  role      String?
  message   String?
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  description String?
  adCopy      String?
  adImage     String?
  active      Boolean  @default(true)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}
