# Neon PostgreSQL — pooled connection for app runtime
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Neon PostgreSQL — direct connection for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin CMS (used on admin-cms branch only, not on public site)
ADMIN_EMAIL="kylene@bowtienetwork.com"
ADMIN_PASSWORD_HASH=""
ADMIN_JWT_SECRET="change-me-to-a-random-string"

# AWS (for deployment)
AWS_REGION="us-east-1"

# Lead Capture — Google Apps Script webhook
# Required in production. Omit in local dev to use file-based fallback.
LEADS_WEBHOOK_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
# Optional shared secret for webhook authentication
LEADS_WEBHOOK_SECRET=""
