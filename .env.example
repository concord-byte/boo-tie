# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bowtie?schema=public"

# Admin
ADMIN_JWT_SECRET="change-me-to-a-random-string"

# AWS (for deployment)
AWS_REGION="us-east-1"

# Lead Capture — Google Apps Script webhook
# Required in production. Omit in local dev to use file-based fallback.
LEADS_WEBHOOK_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
# Optional shared secret for webhook authentication
LEADS_WEBHOOK_SECRET=""
